             RowBox[{"V", "[", "t", "]"}], ",", 
             RowBox[{"P", "[", "t", "]"}], ",", 
             FractionBox[
              RowBox[{"W", "[", "t", "]"}], 
              RowBox[{
               RowBox[{"W", "[", "t", "]"}], "+", 
               RowBox[{"V", "[", "t", "]"}]}]], ",", 
