Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Parameters", " ", "and", " ", "model", " ", "prediction", " ", "for", " ",
     "Glaucoma", " ", "treatment"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"solTetra", " ", "=", " ", 
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"eq", ",", 
         RowBox[{
          RowBox[{"W", "[", "0", "]"}], "\[Equal]", "10"}], ",", " ", 
         RowBox[{
          RowBox[{"V", "[", "0", "]"}], "\[Equal]", " ", "10"}], ",", " ", 
         RowBox[{
          RowBox[{"P", "[", "0", "]"}], "\[Equal]", " ", "2"}]}], "}"}], "/.", 
       RowBox[{"{", "  ", 
        RowBox[{
         RowBox[{"rw", "\[Rule]", "0.543"}], ",", 
         RowBox[{"rv", "\[Rule]", "0.363"}], ",", 
         RowBox[{"avw", " ", "\[Rule]", "1.3"}], ",", 
         RowBox[{"awv", "\[Rule]", "0.35"}], ",", 
         RowBox[{"dvp", "\[Rule]", " ", "0.025"}], ",", 
         RowBox[{"dwp", "\[Rule]", "0.12"}], ",", 
         RowBox[{"Kw", "\[Rule]", " ", "50"}], ",", 
         RowBox[{"Kv", "\[Rule]", "50"}], ",", 
         RowBox[{"\[Eta]wp", "\[Rule]", "0.08"}], ",", 
         RowBox[{"\[Eta]vp", "\[Rule]", "0.08"}], ",", 
         RowBox[{"e", "\[Rule]", "0.1"}], ",", 
         RowBox[{"m", "\[Rule]", " ", "0.1"}]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"W", ",", "V", ",", "P"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "15"}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"dat", " ", "=", 
    RowBox[{
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Evaluate", "[", 
          RowBox[{
           RowBox[{"{", 
